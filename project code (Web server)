#include <WiFi.h>
#include <WebServer.h>
#include <ESPmDNS.h>
#include <DHT.h>

const char *ssid = "Sadi Wifi";
const char *password = "11279112";

#define DHTPIN 23
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);
WebServer server(80);

// -------- FUNCTION DECLARATIONS (Good Practice) --------
void handleRoot();
void handleData();

// ----------- SENSOR API -------------
void handleData() {
  float t = dht.readTemperature();
  float h = dht.readHumidity();

  if (isnan(t) || isnan(h)) {
    server.send(200, "application/json", "{\"temp\":0,\"hum\":0}");
    return;
  }

  String json = "{\"temp\":" + String(t) + ",\"hum\":" + String(h) + "}";
  server.send(200, "application/json", json);
}

// ----------- MAIN PAGE -------------
void handleRoot() {
  server.send(200, "text/html", R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta name='viewport' content='width=device-width, initial-scale=1'>
<title>ESP32 Smart Dashboard</title>

<link href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap' rel='stylesheet'>

<style>
body {
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(135deg,#1e3c72,#2a5298);
  color: white;
  text-align: center;
}

.card {
  background: rgba(255,255,255,0.1);
  margin: 15px auto;
  padding: 20px;
  border-radius: 20px;
  width: 80%;
  max-width: 400px;
}

.value {
  font-size: 2.5rem;
  font-weight: bold;
}

.small {
  font-size: 1rem;
  opacity: 0.7;
}
</style>
</head>

<body>

<h2>ESP32 Smart Monitor</h2>

<div class='card'>
  <div>Temperature</div>
  <div class='value' id='temp'>--</div>
</div>

<div class='card'>
  <div>Humidity</div>
  <div class='value' id='hum'>--</div>
</div>

<div class='card'>
  <div>Time</div>
  <div class='small' id='time'></div>
</div>

<script>

// -------- LIVE SENSOR DATA --------
setInterval(() => {
  fetch('/data')
    .then(res => res.json())
    .then(data => {
      document.getElementById('temp').innerHTML = data.temp + " &deg;C";
      document.getElementById('hum').innerHTML = data.hum + " %";
    });
}, 2000);

// -------- TIME --------
setInterval(() => {
  let now = new Date();
  document.getElementById('time').innerHTML = now.toLocaleString();
}, 1000);

</script>

</body>
</html>
)rawliteral");
}

// -------- SETUP --------
void setup() {
  Serial.begin(115200);
  dht.begin();

  WiFi.begin(ssid, password);
  Serial.print("Connecting");

  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
    Serial.print(".");
  }

  Serial.println("\nConnected!");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/data", handleData);

  server.begin();
}

// -------- LOOP --------
void loop() {
  server.handleClient();
}
